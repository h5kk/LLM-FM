{
  "description": "Feature Memory lifecycle hooks. Tracks file edits, injects context at session start, and reports documentation gaps at session end. Each hook is launched through _run.py, a polyglot bootstrap that guarantees the Python 3 hooks run even when `python` resolves to Python 2.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_run.py", "claude_session_start"],
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_run.py", "claude_post_tool"],
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_run.py", "claude_stop"],
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
